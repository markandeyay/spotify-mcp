# spotify-mcp environment variables (spotifymcp.md Section 13)
# Copy to .env and fill in real values. Never commit .env.

# HTTP port the server listens on (hosting providers may inject this)
PORT=3000

# The server's public HTTPS URL, used to build redirect URIs and OAuth metadata
PUBLIC_BASE_URL=https://your-app.onrender.com

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/spotify_mcp?sslmode=require

# Client ID of your single owner-registered Spotify app
SPOTIFY_CLIENT_ID=your-spotify-client-id

# Client secret of that Spotify app
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Must be ${PUBLIC_BASE_URL}/callback and registered in the Spotify developer dashboard
SPOTIFY_REDIRECT_URI=https://your-app.onrender.com/callback

# 32-byte base64 key for AES-256-GCM token encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
MASTER_ENCRYPTION_KEY=

# Secret key (32+ chars) for signing the access tokens this server issues to MCP clients
JWT_SIGNING_KEY=

# Lifetime in seconds of access tokens issued to MCP clients (default 3600)
TOKEN_ACCESS_TTL_SECONDS=3600

# Lifetime in seconds of refresh tokens issued to MCP clients (default 2592000 = 30 days)
TOKEN_REFRESH_TTL_SECONDS=2592000

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# development | test | production
NODE_ENV=development
